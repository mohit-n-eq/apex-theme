{% assign icon_height = icon_height | default: '24px' %}
{% assign icon_width = icon_width | default: '24px' %}
{% assign icon_color = icon_color | default: 'currentColor' %}
{% assign icon_classes = icon_classes %}
{% assign icon_attributes = icon_attributes %}

{% case icons %}
  {% when 'icon-search' %}
    <svg
      xmlns='http://www.w3.org/2000/svg'
      class='size-6 {{ icon_classes }}'
      width='{{ icon_width }}'
      height='{{ icon_height }}'
      fill='{{ icon_color }}'
      viewBox='0 0 24 24'
      stroke-width='1.5'
      stroke='currentColor'
      {{ icon_attributes }}
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
    </svg>

  {% when 'icon-cart' %}
    <svg
      xmlns='http://www.w3.org/2000/svg'
      class='size-6 {{ icon_classes }}'
      width='{{ icon_width }}'
      height='{{ icon_height }}'
      fill='{{ icon_color }}'
      viewBox='0 0 24 24'
      stroke-width='1.5'
      stroke='currentColor'
      {{ icon_attributes }}
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
    </svg>

  {% when 'icon-account' %}
    <svg
      xmlns='http://www.w3.org/2000/svg'
      class='size-6 {{ icon_classes }}'
      width='{{ icon_width }}'
      height='{{ icon_height }}'
      fill='{{ icon_color }}'
      viewBox='0 0 24 24'
      stroke-width='1.5'
      stroke='currentColor'
      {{ icon_attributes }}
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M17.982 18.725A7.488 7.488 0 0 0 12 15.75a7.488 7.488 0 0 0-5.982 2.975m11.963 0a9 9 0 1 0-11.963 0m11.963 0A8.966 8.966 0 0 1 12 21a8.966 8.966 0 0 1-5.982-2.275M15 9.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
    </svg>

  {% when 'icon-hamburger' %}
    <svg
      xmlns='http://www.w3.org/2000/svg'
      class='size-6 {{ icon_classes }}'
      width='{{ icon_width }}'
      height='{{ icon_height }}'
      fill='{{ icon_color }}'
      viewBox='0 0 24 24'
      stroke-width='1.5'
      stroke='currentColor'
      {{ icon_attributes }}
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 5.25h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5" />
    </svg>
{% endcase %}
