<!doctype html>
<html lang='en'>
  <head>
    {{ content_for_header }}

    {% if settings.favicon != blank %}
      <link rel='icon' type='image/png' href='{{ settings.favicon | image_url: width: 32, height: 32 }}'>
    {% endif %}

    {% render 'stylesheets' %}
    {% render 'scripts' %}
  </head>
  <body>
    {{ content_for_layout }}
  </body>
</html>
